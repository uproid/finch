{
  "name": "finch-assets",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "tailwind:build": "tailwindcss -c tailwind.config.js -i ./public/assets/tailwind.input.css -o ./public/assets/generated-tailwind.css --minify",
